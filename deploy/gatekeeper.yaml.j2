{# Skeletor template for cyclops's per-app gatekeeper config fragment.
   Mirrors cyclops/deploy/gatekeeper-cyclops-{staging,prod}.yaml. #}
# Gatekeeper app config fragment for {{ "cyclops-staging" if env == "staging" else "cyclops" }} ({{ env }}).
# Managed by skeletor — edit templates/gatekeeper/cyclops.yaml.j2 in the
# skeletor repo, then `ansible-playbook playbooks/deploy-gatekeeper-config.yml
# -e app_slug=cyclops -e env={{ env }}` to roll out.

name: {{ "\"Cyclops (Staging)\"" if env == "staging" else "\"Cyclops\"" }}
domains:
  - {{ "cyclops-staging.callendina.com" if env == "staging" else "cyclops.callendina.com" }}
protected_paths:
  - /*
# Tight allowlist — the cyclops stack is operator-internal.
allowed_emails:
  - jonno@callendina.com
  - jonnosan@gmail.com
  - jonno.downes@callendina.com
roles:
  - admin
default_role: admin
api_access:
  mode: key_required
  # Programmatic paths require an X-API-Key. Browser paths (/grafana/*,
  # /, /events, /app/<x>, etc.) accept session cookies normally.
  paths:
    - /api/dev/*
  registered_key_duration_days: 365
rate_limit:
  # Bumped well above gatekeeper's 120/min default — Grafana iframes
  # fan out into many concurrent panel queries, and signed-in admins
  # are operator-internal so the abuse risk is low.
  requests_per_minute: 600
  authenticated_requests_per_minute: 3000
