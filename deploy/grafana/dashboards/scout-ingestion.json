{
  "uid": "scout-ingestion",
  "title": "Scout — Ingestion",
  "tags": ["scout", "ingestion", "cms"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CMS calls (24h)",
      "description": "Every outbound HTTP request via api/http_cache.py. Excludes anthropic.messages.create.",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "sum(count_over_time({app=\"scout\"} | json | event_type=\"api.call\" | target!=\"anthropic.messages.create\" [24h]))",
        "instant": true
      }],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CMS failures (24h)",
      "description": "outcome=failure on any non-anthropic api.call. Spike = a CMS is down.",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "sum(count_over_time({app=\"scout\"} | json | event_type=\"api.call\" | target!=\"anthropic.messages.create\" | outcome=\"failure\" [24h]))",
        "instant": true
      }],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 50}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache hits (24h)",
      "description": "requests_cache returned a cached response → no upstream call. Higher = cheaper, faster.",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "sum(count_over_time({app=\"scout\"} | json | event_type=\"api.call\" | target!=\"anthropic.messages.create\" | cache_hit=\"true\" [24h]))",
        "instant": true
      }],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache misses (24h)",
      "description": "Real upstream requests. Sustained high count for a single host = cache TTL too short or misconfigured.",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "sum(count_over_time({app=\"scout\"} | json | event_type=\"api.call\" | target!=\"anthropic.messages.create\" | cache_hit=\"false\" [24h]))",
        "instant": true
      }],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Calls per hour, top targets",
      "description": "topk(10) target paths over the period. Top entries should be the active CMSs (squadi, nbl1, geniussports, etc).",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "topk(10, sum by (target) (count_over_time({app=\"scout\"} | json | event_type=\"api.call\" | target!=\"anthropic.messages.create\" [1h])))",
        "legendFormat": "{{ target }}"
      }],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 20}}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p95 latency by target (ms, top 10)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "topk(10, quantile_over_time(0.95, {app=\"scout\"} | json | event_type=\"api.call\" | target!=\"anthropic.messages.create\" | unwrap duration_ms [10m]) by (target))",
        "legendFormat": "{{ target }}"
      }],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 7,
      "type": "table",
      "title": "Cache hit ratio by target (24h, top 20)",
      "description": "Higher % = effective caching. 0% = TTL too short or always-uncached path. ~100% = TTL too long maybe.",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "topk(20, sum by (target, cache_hit) (count_over_time({app=\"scout\"} | json | event_type=\"api.call\" | target!=\"anthropic.messages.create\" [24h])))",
        "instant": true,
        "format": "table"
      }]
    },
    {
      "id": 8,
      "type": "table",
      "title": "NBL1 East games refreshed (24h)",
      "description": "scout.match.refreshed events for NBL1M (East Men) and NBL1W (East Women) — the only comps the local backfill targets. Same game refreshed twice in the window counts twice (sweep frequency).",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (competition_id) (count_over_time({app=\"scout\"} | json | event_type=\"scout.match.refreshed\" | competition_id=~\"NBL1[MW]\" [24h]))",
        "instant": true,
        "format": "table"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "NBL1 East refresh rate (7d)",
      "description": "Daily count of scout.match.refreshed events, NBL1 East only. Trend line for backfill progress — should rise during active local backfill, plateau when caught up.",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (competition_id) (count_over_time({app=\"scout\"} | json | event_type=\"scout.match.refreshed\" | competition_id=~\"NBL1[MW]\" [1d]))",
        "legendFormat": "{{ competition_id }}"
      }],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}}}}
    },
    {
      "id": 10,
      "type": "table",
      "title": "Other comps refreshed (24h, non-East)",
      "description": "Everything outside NBL1 East — mostly the prod sweep cron touching current-season YL / JPL / NBL1 East 2026 games as they progress. Background activity, not the backfill target.",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (competition_id) (count_over_time({app=\"scout\"} | json | event_type=\"scout.match.refreshed\" | competition_id!~\"NBL1[MW]\" [24h]))",
        "instant": true,
        "format": "table"
      }]
    }
  ]
}
