{
  "uid": "cyclops-per-app",
  "title": "Cyclops — Per App",
  "tags": ["cyclops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "cyclops-loki"
        },
        "query": {
          "type": 1,
          "label": "app",
          "stream": "{source=\"cyclops\"}"
        },
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Events / min",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({app=\"$app\", source=\"cyclops\"}[1m])) * 60"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors / min (last 5m)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({app=\"$app\", source=\"cyclops\", level=~\"error|critical\"}[5m])) * 60"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 1}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active components",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (component) (count_over_time({app=\"$app\", source=\"cyclops\"}[5m])))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Hosts emitting (5m)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (host) (count_over_time({app=\"$app\", source=\"cyclops\"}[5m])))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Events / sec by level",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (rate({app=\"$app\", source=\"cyclops\"}[$__rate_interval]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": {"mode": "normal"}
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "error"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "critical"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]
          },
          {
            "matcher": {"id": "byName", "options": "warning"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
          },
          {
            "matcher": {"id": "byName", "options": "info"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]
          },
          {
            "matcher": {"id": "byName", "options": "debug"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "grey"}}]
          }
        ]
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "list"}
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top event_types (last 1h)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, sum by (event_type) (count_over_time({app=\"$app\", source=\"cyclops\"} | json [1h])))",
          "queryType": "instant",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {"Value #A": "count", "event_type": "event_type"}
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent events",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 14},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"$app\", source=\"cyclops\"} | json | line_format \"{{.event_type}}{{ if .outcome }} ({{.outcome}}){{ end }} {{ .request_id | default \\\"\\\" }}\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
