{
  "uid": "cyclops-errors",
  "title": "Cyclops — Errors",
  "tags": ["cyclops", "errors"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Errors (last 1h)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({source=\"cyclops\", level=~\"error|critical\"}[1h]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warnings (last 1h)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({source=\"cyclops\", level=\"warning\"}[1h]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Apps with errors (1h)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (app) (count_over_time({source=\"cyclops\", level=~\"error|critical\"}[1h])))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Distinct error_types (1h)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (error_type) (count_over_time({source=\"cyclops\", level=~\"error|critical\"} | json [1h])))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Error rate by app",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (app) (rate({source=\"cyclops\", level=~\"error|critical\"}[$__interval]))",
          "legendFormat": "{{app}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top error_type by app",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(30, sum by (app, error_type, event_type) (count_over_time({source=\"cyclops\", level=~\"error|critical\"} | json [1h])))",
          "queryType": "instant",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {"Value #A": "count"}
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent errors",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 14},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "{source=\"cyclops\", level=~\"error|critical\"} | json | line_format \"[{{ .app }}] {{ .event_type }} :: {{ .error_type | default \\\"\\\" }} {{ .error_message | default \\\"\\\" }}\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
