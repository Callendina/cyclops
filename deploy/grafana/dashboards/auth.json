{
  "uid": "cyclops-auth",
  "title": "Cyclops — Auth",
  "tags": ["cyclops", "auth", "gatekeeper"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Accesses (last 1h)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" [1h]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Allowed (last 1h)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" | status=\"allowed\" [1h]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "green"}
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Denied (last 1h)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" | status!=\"allowed\" [1h]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 100}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Distinct users (1h)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (masked_email) (count_over_time({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" | masked_email!=\"\" [1h])))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Access rate by app",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (app_slug) (rate({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" [$__rate_interval]))",
          "legendFormat": "{{app_slug}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": {"mode": "normal"}
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Access rate by status",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" [$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top users by access count (1h)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, sum by (masked_email, app_slug) (count_over_time({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" | masked_email!=\"\" [1h])))",
          "queryType": "instant",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {"Value #A": "count"}
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Denials by app + status (1h)",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(30, sum by (app_slug, status) (count_over_time({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" | status!=\"allowed\" [1h])))",
          "queryType": "instant",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {"Value #A": "count"}
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Login completions by provider",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 7},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, outcome) (rate({app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.login.completed\" [$__rate_interval]))",
          "legendFormat": "{{provider}} ({{outcome}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Recent denials",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 7},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"gatekeeper\", source=\"cyclops\"} | json | event_type=\"gatekeeper.access\" | status!=\"allowed\" | line_format \"[{{ .app_slug }}] {{ .status }} {{ .method }} {{ .path }} ip={{ .ip }} user={{ .masked_email }}\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
