{
  "uid": "cyclops-fleet",
  "title": "Cyclops — Fleet",
  "tags": ["cyclops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Apps emitting (last 5m)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (app) (count_over_time({source=\"cyclops\"}[5m])))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total events / min",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({source=\"cyclops\"}[1m])) * 60"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors / min (last 5m)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({source=\"cyclops\", level=~\"error|critical\"}[5m])) * 60"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 1}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active hosts",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (host) (count_over_time({source=\"cyclops\"}[5m])))"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Events / sec by app",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (app) (rate({source=\"cyclops\"}[$__interval]))",
          "legendFormat": "{{app}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": {"mode": "normal"}
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors / sec by app",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (app) (rate({source=\"cyclops\", level=~\"error|critical\"}[$__interval]))",
          "legendFormat": "{{app}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Apps by event volume (last 1h)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, sum by (app, component) (count_over_time({source=\"cyclops\"}[1h])))",
          "queryType": "instant",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {"Value #A": "count"}
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Recent fleet activity",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "cyclops-loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "{source=\"cyclops\"} | json | line_format \"[{{ .app }}] {{ .event_type }}\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
